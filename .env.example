# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://ciclica.pro

# Asistente IA (chat de recomendaciones por fase del ciclo)
# Proveedor principal: OpenAI (más económico). Respaldo: Anthropic Sonnet.
# Se necesita al menos una de las dos keys; sin ninguna, /api/chat devuelve 503.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (opcional — sin esto, los endpoints de Stripe devuelven 503)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Mercado Pago (opcional — sin esto, los endpoints de MP devuelven 503)
MP_ACCESS_TOKEN=APP_USR-...
MP_PLAN_AMOUNT=4.99
MP_CURRENCY=USD
# Secret para verificar firma del webhook (Configuraciones > Webhooks en MP)
MP_WEBHOOK_SECRET=
